{
  "name": "arena",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "svelte-kit sync",
    "dev": "concurrently -k \"node server/index.js\" \"vite dev\"",
    "build": "vite build",
    "preview": "vite build && NODE_ENV=production node server/index.js",
    "start": "NODE_ENV=production node server/index.js",
    "server": "node server/index.js",
    "test": "node scripts/smoke.mjs",
    "test:cloud": "node scripts/test-cloud.mjs",
    "diagnose": "node scripts/diagnose.mjs",
    "restart": "node scripts/restart.mjs",
    "restart:dev": "node scripts/restart.mjs --dev",
    "kill": "node scripts/restart.mjs --kill"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.0.4",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "svelte": "^5.16.0",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7"
  }
}
