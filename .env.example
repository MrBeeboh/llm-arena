# llama-server binary (SYCL build for Intel Arc B70)
LLAMA_BIN=/home/mike/llama.cpp/build_sycl/bin/llama-server
LLAMA_PORT=8080

# Arena server port
PORT=5175

# Vite dev UI port (must match scripts/restart.mjs wait list and launch-arena.sh default URL)
# VITE_DEV_PORT=5173

# Models directory
MODELS_DIR=./models

# Hard cap on model load. While llama-server is still actively writing to stderr the
# deadline auto-extends (see ARENA_LOAD_STALL_MS), so this only triggers if the load
# is genuinely stuck. Bump if you load very large models on slow storage.
LOAD_TIMEOUT_MS=600000

# How long stderr can be quiet before we declare a stalled load (default 60s).
# ARENA_LOAD_STALL_MS=60000

# Set to 1 if llama-server is NOT an Intel oneAPI/SYCL build (CUDA/CPU/Vulkan).
# Otherwise Arena strips deprecated SYCL_DEVICE_FILTER on the child. For SYCL-looking
# binaries (path contains "sycl"/"oneapi"), if ONEAPI_DEVICE_SELECTOR is unset it sets
# ONEAPI_DEVICE_SELECTOR=level_zero:gpu so ggml_sycl_init can select a GPU (minimal-env fix).
# ARENA_NO_SYCL_ENV=1

# Optional: override that default (examples: level_zero:gpu, opencl:gpu).
# ARENA_SYCL_DEFAULT_DEVICE_SELECTOR=opencl:gpu

# Skip setting any default ONEAPI_DEVICE_SELECTOR (still strips SYCL_DEVICE_FILTER).
# ARENA_SYCL_SKIP_DEVICE_SELECTOR=1

# Hard override for the llama-server child (wins over everything above).
# ARENA_ONEAPI_DEVICE_SELECTOR=level_zero:gpu

# SYCL-linked llama-server needs Intel runtime libs (libsvml.so). If you do not
# `source /opt/intel/oneapi/setvars.sh` before starting Arena, prepend dirs here, e.g.:
# ARENA_EXTRA_LD_LIBRARY_PATH=/opt/intel/oneapi/compiler/latest/lib
#
# Arena auto-prepends common /opt/intel/oneapi paths when LLAMA_BIN path contains "sycl".
# ARENA_AUTO_ONEAPI_LD=0   # disable auto-prepending
# ARENA_AUTO_ONEAPI_LD=1   # always prepend (even for non-sycl paths)

# Desktop launcher (`scripts/launch-arena.sh`) sources `/opt/intel/oneapi/setvars.sh` when
# present so SYCL llama-server can see the GPU. Disable with ARENA_NO_SETVARS=1.

# Sanity check before filing bugs: discovers GGUF files and runs `ldd` with Arena's llama spawn env.
# npm run diagnose

# Cloud judge API key (xAI Grok default)
JUDGE_API_KEY=
JUDGE_BASE_URL=https://api.x.ai/v1
JUDGE_MODEL=grok-4-1-fast-non-reasoning

# Optional: max upload size for Import .gguf (bytes). Default ~120GB.
# MAX_MODEL_UPLOAD_BYTES=128849018880
